{
  "permissions": {
    "allow": [
      "Bash(hugo version)",
      "Bash(git init)",
      "Bash(brew --version)",
      "Bash(brew install hugo)",
      "Bash(hugo new site . --force)",
      "Bash(git submodule add --depth 1 https://github.com/adityatelange/hugo-PaperMod.git themes/PaperMod)",
      "Bash(hugo new about.md)",
      "Bash(hugo new resume.md)",
      "Bash(git submodule update --init --recursive)",
      "Bash(hugo --minify)",
      "Bash(hugo server -D)",
      "Bash(git submodule status)",
      "Bash(hugo config | grep -A2 -B2 \"baseURL\")",
      "Bash(hugo --minify --baseURL=\"http://localhost:1313/\" 2>&1 | head -20)",
      "Bash(hugo config --logLevel error | head -100)",
      "Bash(git rm -r --cached public/)",
      "Bash(git stash pop)",
      "Bash(git add .claude/settings.local.json)",
      "Bash(git add -u)"
    ]
  }
}
